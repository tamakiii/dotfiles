#!/bin/sh
set -eu

pane_path="$1"
window_id="$2"

case "$pane_path" in
  "$HOME"/Git/*/*)
    # Extract workspace name (last matching component)
    workspace="${pane_path#"$HOME"/Git/*/}"
    workspace="${workspace%%/*}"
    tmux rename-window -t "$window_id" "$workspace"
    tmux set-option -t "$window_id" automatic-rename off
    ;;
esac
