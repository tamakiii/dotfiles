#!/bin/bash
# Launch Claude Code in a tmux pane
# Designed for programmatic use by Claude via Bash tool
#
# Usage:
#   tmux-claude-launch <target> [message]      Launch claude in an idle pane

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: tmux-claude-launch <target> [message]" >&2
  exit 1
fi

target="$1"
message="${2:-}"

# Verify pane exists and is idle
cmd=$(tmux display-message -t "$target" -p '#{pane_current_command}' 2>/dev/null) || {
  echo "Error: pane $target not found" >&2
  exit 1
}

if [[ "$cmd" != "zsh" ]]; then
  echo "Error: pane $target is running '$cmd', expected idle shell (zsh)" >&2
  exit 1
fi

# Launch claude
tmux send-keys -t "$target" "claude" Enter

# If message provided, wait for claude to start then send
if [[ -n "$message" ]]; then
  for i in $(seq 1 30); do
    sleep 1
    cmd=$(tmux display-message -t "$target" -p '#{pane_current_command}')
    [[ "$cmd" == "claude" ]] && break
  done

  if [[ "$cmd" != "claude" ]]; then
    echo "Error: claude did not start within 30s in $target" >&2
    exit 1
  fi

  sleep 3
  tmux send-keys -t "$target" -l "$message"
  tmux send-keys -t "$target" Enter
fi

echo "Launched claude in $target"
