#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gh CLI that authenticates as tamakiii-openclaw[bot].
# Usage: .openclaw/bin/gh pr create --repo tamakiii/sandbox-bevy --title "..."

REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${REAL_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

export GH_TOKEN="$("${REPO_ROOT}/bin/gh-app-token" \
  "$(pass show tamakiii/github.com/tamakiii-openclaw/app-id)" \
  "$(pass show tamakiii/github.com/tamakiii-openclaw/installation-id)" \
  <(pass show tamakiii/github.com/tamakiii-openclaw.pem))"

exec /usr/bin/gh "$@"
