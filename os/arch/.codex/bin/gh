#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gh CLI that authenticates as tamakiii-codex[bot].
# Usage: .codex/bin/gh pr review 2 --repo tamakiii/sandbox-bevy --approve

REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${REAL_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

export GH_TOKEN="$("${REPO_ROOT}/bin/gh-app-token" \
  "$(pass show tamakiii/github.com/tamakiii-codex/app-id)" \
  "$(pass show tamakiii/github.com/tamakiii-codex/installation-id)" \
  <(pass show tamakiii/github.com/tamakiii-codex.pem))"

exec /usr/bin/gh "$@"
