#!/bin/bash
# Machine-readable status of all Claude Code panes
# Output: TSV (target, status, session, window, path, branch)
# Status: alert (permission prompt), active (working), idle (waiting)

set -euo pipefail

while IFS=$'\t' read -r cmd session window path target; do
  [[ "$cmd" == "claude" ]] || continue

  branch=$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null) || branch=""

  content=$(tmux capture-pane -t "$target" -p -S -20 2>/dev/null) || continue
  bottom=$(echo "$content" | tail -10)

  if echo "$bottom" | grep -q "Do you want to" && echo "$bottom" | grep -q "Esc to cancel"; then
    status="alert"
  elif echo "$content" | grep -qE '\([0-9]+[hms]( [0-9]+[smh])? ·'; then
    status="active"
  else
    status="idle"
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$target" "$status" "$session" "$window" "$path" "$branch"
done < <(tmux list-panes -a -F '#{pane_current_command}	#{session_name}	#{window_name}	#{pane_current_path}	#{session_name}:#{window_index}.#{pane_index}' | sort -t$'\t' -k2,2)
