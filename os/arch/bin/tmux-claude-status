#!/bin/bash
# Show status of all Claude Code panes
# Usage: run in any pane, or bind to a tmux key

set -euo pipefail

RED=$'\033[1;31m'
YELLOW=$'\033[1;33m'
DIM=$'\033[2m'
RESET=$'\033[0m'

summaries=""
alerts=""

while IFS=$'\t' read -r cmd target label; do
  if [[ "$cmd" == "claude" ]]; then
    content=$(tmux capture-pane -t "$target" -p -S -20)

    if echo "$content" | grep -qE "Do you want to (proceed|allow)"; then
      alerts+="${RED}⚠  ${label} (${target})${RESET}"$'\n'
      alerts+="$(echo "$content" | sed -n '/Do you want/,$ p' | grep -v '^[[:space:]]*$' | head -6 | sed 's/^/   /')"$'\n\n'
    else
      time_str=$(echo "$content" | grep -oE 'for [0-9]+[hms]( [0-9]+[smh])?' | tail -1) || true
      if [[ -n "$time_str" ]]; then
        printf -v line "${YELLOW}●${RESET}  %-50s ${DIM}%s${RESET}\n" "$label ($target)" "$time_str"
      else
        printf -v line "${DIM}○  %s (%s)${RESET}\n" "$label" "$target"
      fi
      summaries+="$line"
    fi
  fi
done < <(tmux list-panes -a -F '#{pane_current_command}	#{session_name}:#{window_index}.#{pane_index}	#{session_name}/#{window_name}')

if [[ -z "$summaries" && -z "$alerts" ]]; then
  echo "No Claude panes found."
else
  [[ -n "$summaries" ]] && printf '%s' "$summaries"
  if [[ -n "$alerts" ]]; then
    [[ -n "$summaries" ]] && echo
    printf '%s' "$alerts"
  fi
fi
