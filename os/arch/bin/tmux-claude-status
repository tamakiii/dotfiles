#!/bin/bash
# Show status of all Claude Code panes
# Usage: run in any pane, or bind to a tmux key

set -euo pipefail

RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
MAGENTA=$'\033[1;35m'
DIM=$'\033[2m'
RESET=$'\033[0m'

git_status() {
  local path="$1"
  local staged=0 modified=0 untracked=0
  local parts=()

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local x="${line:0:1}" y="${line:1:1}"
    [[ "$x" =~ [MADRC] ]] && ((staged++)) || true
    [[ "$y" =~ [MD] ]] && ((modified++)) || true
    [[ "$x" == "?" ]] && ((untracked++)) || true
  done < <(git -C "$path" status --porcelain 2>/dev/null)

  local shortstat
  shortstat=$(git -C "$path" diff HEAD --shortstat 2>/dev/null) || true
  local ins del
  ins=$(echo "$shortstat" | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+') || true
  del=$(echo "$shortstat" | grep -oE '[0-9]+ deletion' | grep -oE '[0-9]+') || true

  [[ $staged -gt 0 ]] && parts+=("${GREEN}â—Ź ${staged}${RESET}")
  [[ $modified -gt 0 ]] && parts+=("${RED}âśš ${modified}${RESET}")
  [[ $untracked -gt 0 ]] && parts+=("${MAGENTA}â€¦ ${untracked}${RESET}")
  [[ -n "$ins" ]] && parts+=("${GREEN}+${ins}${RESET}")
  [[ -n "$del" ]] && parts+=("${RED}-${del}${RESET}")

  if [[ ${#parts[@]} -eq 0 ]]; then
    echo "${GREEN}âś”${RESET}"
  else
    echo "${parts[*]}"
  fi
}

summaries=""
alerts=""

while IFS=$'\t' read -r cmd session window path target; do
  if [[ "$cmd" == "claude" ]]; then
    short_path="${path/#$HOME/\~}"
    branch=$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null) || true
    branch_str=""
    git_str=""
    if [[ -n "$branch" ]]; then
      branch_str=" ${DIM}(${branch})${RESET}"
      git_str=" $(git_status "$path")"
    fi

    content=$(tmux capture-pane -t "$target" -p -S -20)

    if echo "$content" | grep -qE "Do you want to (proceed|allow)"; then
      alerts+="${RED}âš   ${session} / ${window}${RESET}${branch_str}${git_str}"$'\n'
      alerts+="   ${DIM}${cmd} @ ${short_path}${RESET}"$'\n'
      alerts+="$(echo "$content" | sed -n '/Do you want/,$ p' | grep -v '^[[:space:]]*$' | head -6 | sed 's/^/   /')"$'\n\n'
    else
      time_str=$(echo "$content" | grep -oE 'for [0-9]+[hms]( [0-9]+[smh])?' | tail -1) || true
      time_part=""
      [[ -n "$time_str" ]] && time_part="  ${DIM}${time_str}${RESET}"

      if [[ -n "$time_str" ]]; then
        summaries+="${YELLOW}â—Ź${RESET}  ${session} / ${window}${branch_str}${git_str}${time_part}"$'\n'
      else
        summaries+="${DIM}â—‹  ${session} / ${window}${branch_str}${RESET}${git_str}"$'\n'
      fi
      summaries+="   ${DIM}${cmd} @ ${short_path}${RESET}"$'\n'
    fi
  fi
done < <(tmux list-panes -a -F '#{pane_current_command}	#{session_name}	#{window_name}	#{pane_current_path}	#{session_name}:#{window_index}.#{pane_index}')

if [[ -z "$summaries" && -z "$alerts" ]]; then
  echo "No Claude panes found."
else
  [[ -n "$summaries" ]] && printf '%s' "$summaries"
  if [[ -n "$alerts" ]]; then
    [[ -n "$summaries" ]] && echo
    printf '%s' "$alerts"
  fi
fi
