#!/bin/bash
# Open helix in a tmux popup overlay
# Symlinked as a "GUI editor" name (e.g. codium) from Claude Code's
# whitelist so it doesn't clear the TUI when invoking C-x C-e.
# Claude's last response stays visible underneath the popup.

set -euo pipefail

if [[ -n "${TMUX:-}" ]]; then
  channel="editor-$$"
  pane_width=$(tmux display-message -p '#{pane_width}')
  tmux display-popup -E -x "$pane_width" -w 50% -h 100% "helix '$1'; tmux wait-for -S '$channel'"
  tmux wait-for "$channel"
else
  helix "$1"
fi
