#!/bin/bash
# Open helix in a tmux split below, showing captured scrollback above
# Use as EDITOR=tmux-editor so tools like Claude Code's C-x C-e
# keep the last output visible while editing.

set -euo pipefail

channel="editor-$$"

# Capture scrollback before it's lost (Claude clears its TUI, but
# tmux may still have content in the scroll history)
scrollback=$(tmux capture-pane -p -S -500 2>/dev/null || true)

# Open helix in a split below
tmux split-window -v -l 70% "helix '$1'; tmux wait-for -S '$channel'"

# Show captured scrollback in the top pane (this terminal)
printf '%s\n' "$scrollback" | grep -v '^$' | tail -50

tmux wait-for "$channel"
