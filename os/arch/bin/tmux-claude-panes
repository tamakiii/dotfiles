#!/bin/bash
# Navigate Claude Code panes via tmux display-menu
# Alert panes shown first with "!" prefix, active with "*"

set -euo pipefail

menu_args=(-T "Claude")
key=0
has_entries=false

while IFS=$'\t' read -r target status session window path branch; do
  has_entries=true
  case "$status" in
    alert)  prefix="! " ;;
    active) prefix="* " ;;
    *)      prefix="  " ;;
  esac
  label="${prefix}${session}/${window}"
  menu_args+=("$label" "$key" "switch-client -t '$target'")
  key=$(( key + 1 ))
done < <(tmux-claude-status | sort -t$'\t' -k2,2)

if [[ "$has_entries" == false ]]; then
  tmux display-message "No Claude panes"
  exit 0
fi

tmux display-menu "${menu_args[@]}"
