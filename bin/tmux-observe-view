#!/bin/bash
# tmux-observe-view — pick a pane on the main tmux server and open a
# read-only view of it in the calling pane of the observe server.
# Designed to be invoked from a tmux display-popup so fzf has a TTY.
#
# After picking, replaces the calling pane's process with
# `tmux-main view --zoom <target>` via respawn-pane. The popup then
# closes and the caller pane shows the view.
#
# Requires TMUX_CALLER_PANE to be set by the caller (via display-popup -e).

set -euo pipefail

target=$(tmux-main pick) || { printf '\n[cancelled]\nPress Enter: '; read -r; exit 1; }

tmux respawn-pane -k -t "${TMUX_CALLER_PANE}" \
  "tmux-main view --zoom $(printf '%q' "$target")" \
  || { printf '\n[respawn-pane failed]\nPress Enter: '; read -r; exit 1; }
