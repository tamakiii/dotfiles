#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gh CLI that authenticates as tamakiii-doppelganger[bot].
# Usage: .local/bin/gh pr review 2 --repo tamakiii/sandbox-bevy --approve

export GH_TOKEN="$("${HOME}/.local/bin/gh-app-token" \
  "$(pass show tamakiii/github.com/tamakiii-doppelganger/app-id)" \
  "$(pass show tamakiii/github.com/tamakiii-doppelganger/installation-id)" \
  <(pass show tamakiii/github.com/tamakiii-doppelganger.pem))"

# Find the real gh binary, skipping this wrapper
for p in /usr/bin/gh /opt/homebrew/bin/gh; do
  [ -x "$p" ] && exec "$p" "$@"
done
echo "gh: not found" >&2
exit 1
